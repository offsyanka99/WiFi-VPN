<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".ConfigurationActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:paddingHorizontal="4dp"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:title="@string/configuration_title" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingHorizontal="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 1. WireGuard config file -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_wg_config"
                android:textAppearance="?attr/textAppearanceTitleSmall" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardElevation="1dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/configFileName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/config_not_loaded"
                        android:textAppearance="?attr/textAppearanceBodyLarge" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLoadConfig"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/btn_load_config" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClearConfig"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_clear_config" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2. Trusted Wi‑Fi networks -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="start|center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_trusted_wifi"
                    android:textAppearance="?attr/textAppearanceTitleSmall" />

                <ImageButton
                    android:id="@+id/infoTrustedWifi"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="2dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/cd_section_info"
                    android:padding="4dp"
                    android:src="@drawable/ic_info"
                    app:tint="@color/status_off" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardElevation="1dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/trustedWifiSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/trusted_wifi_none"
                        android:textAppearance="?attr/textAppearanceBodyLarge" />

                    <LinearLayout
                        android:id="@+id/trustedWifiList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:boxBackgroundMode="outline">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/ssidInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_wifi_ssid"
                            android:imeOptions="actionDone"
                            android:inputType="text"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAddWifi"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:text="@string/btn_add_wifi" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAddCurrentWifi"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:text="@string/btn_add_current_wifi" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3. Exclude applications from VPN -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="start|center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_excluded_apps"
                    android:textAppearance="?attr/textAppearanceTitleSmall" />

                <ImageButton
                    android:id="@+id/infoExcludedApps"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="2dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/cd_section_info"
                    android:padding="4dp"
                    android:src="@drawable/ic_info"
                    app:tint="@color/status_off" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardElevation="1dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/excludedAppsSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/excluded_none"
                        android:textAppearance="?attr/textAppearanceBodyLarge" />

                    <TextView
                        android:id="@+id/excludedAppsList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:visibility="gone"
                        tools:text="Android Auto\nMaps"
                        tools:visibility="visible" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnChooseExcludedApps"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/btn_choose_excluded_apps" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 4. VPN connection retries -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="start|center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_vpn_retry"
                    android:textAppearance="?attr/textAppearanceTitleSmall" />

                <ImageButton
                    android:id="@+id/infoVpnRetry"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="2dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/cd_section_info"
                    android:padding="4dp"
                    android:src="@drawable/ic_info"
                    app:tint="@color/status_off" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardElevation="1dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_vpn_retry_attempts"
                        android:textAppearance="?attr/textAppearanceBodyLarge" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="start|center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRetryAttemptsMinus"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="48dp"
                            android:padding="0dp"
                            android:text="-"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            app:cornerRadius="8dp" />

                        <TextView
                            android:id="@+id/retryAttemptsValue"
                            android:layout_width="72dp"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="20dp"
                            android:gravity="center"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            tools:text="10" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRetryAttemptsPlus"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="48dp"
                            android:padding="0dp"
                            android:text="+"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            app:cornerRadius="8dp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/label_vpn_retry_delay"
                        android:textAppearance="?attr/textAppearanceBodyLarge" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="start|center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRetryDelayMinus"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="48dp"
                            android:padding="0dp"
                            android:text="-"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            app:cornerRadius="8dp" />

                        <TextView
                            android:id="@+id/retryDelayValue"
                            android:layout_width="72dp"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="20dp"
                            android:gravity="center"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            tools:text="5 s" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRetryDelayPlus"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="48dp"
                            android:padding="0dp"
                            android:text="+"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            app:cornerRadius="8dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 5. Grant VPN permission -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVpnPermission"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/btn_request_vpn" />

            <!-- 5. Battery optimization (allow background) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardElevation="1dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchBatteryOptimization"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_battery_optimization"
                        android:textAppearance="?attr/textAppearanceBodyLarge" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/battery_optimization_help"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/status_off" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 6. Manage app if unused -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardElevation="1dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchManageUnused"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_manage_unused"
                        android:textAppearance="?attr/textAppearanceBodyLarge" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/manage_unused_help"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/status_off" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 7. Auto-start after reboot -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardElevation="1dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchAutoStart"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_auto_start"
                        android:textAppearance="?attr/textAppearanceBodyLarge" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/auto_start_help"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/status_off" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 8. Diagnostic log (email for troubleshooting) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="start|center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_diagnostic_log"
                    android:textAppearance="?attr/textAppearanceTitleSmall" />

                <ImageButton
                    android:id="@+id/infoDiagnosticLog"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="2dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/cd_section_info"
                    android:padding="4dp"
                    android:src="@drawable/ic_info"
                    app:tint="@color/status_off" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                app:cardElevation="1dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchDiagnosticLogging"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_enable_diagnostic_logging"
                        android:textAppearance="?attr/textAppearanceBodyLarge" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSendDiagnosticLog"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:enabled="false"
                        android:text="@string/btn_send_diagnostic_log" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClearDiagnosticLog"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:enabled="false"
                        android:text="@string/btn_clear_diagnostic_log" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
